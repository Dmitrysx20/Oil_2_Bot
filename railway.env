# Подавление предупреждений Node.js
NODE_NO_WARNINGS=1
NODE_OPTIONS=--no-deprecation --no-warnings

# Основные настройки
NODE_ENV=production
PORT=3000

# Webhook
ENABLE_WEBHOOK=false
WEBHOOK_URL=

# Telegram Bot (установите в Railway Dashboard)
# TELEGRAM_BOT_TOKEN=your_token_here

# AI Services (установите в Railway Dashboard)
# OPENAI_API_KEY=your_key_here
# PERPLEXITY_API_KEY=your_key_here

# Database (установите в Railway Dashboard)
# SUPABASE_URL=your_url_here
# SUPABASE_ANON_KEY=your_key_here

# Admin (установите в Railway Dashboard)
# ADMIN_CHAT_IDS=123456789,987654321 