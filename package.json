{
  "name": "aromatherapy-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram бот для ароматерапии с AI и музыкальными рекомендациями",
  "main": "app.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node --no-deprecation app.js",
    "dev": "nodemon --no-deprecation app.js",
    "test": "jest",
    "migrate": "node --no-deprecation migrations/run.js",
    "webhook:set": "node --no-deprecation scripts/setWebhook.js",
    "check:env": "node scripts/checkEnv.js",
    "test:app": "node scripts/testApp.js",
    "test:ai": "node scripts/testAI.js",
    "test:admin": "node scripts/testAdmin.js",
    "test:admin:comprehensive": "node scripts/testAdminComprehensive.js",
    "test:admin:telegram": "node scripts/testAdminTelegram.js",
    "test:subscribers": "node scripts/testSubscribers.js",
    "railway:fix": "node scripts/fixRailwayEnv.js",
    "railway:clean": "node scripts/cleanRailwayEnv.js",
    "railway:debug": "node scripts/debugRailwayEnv.js",
    "railway:force-clean": "node scripts/forceCleanRailway.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.2",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "node-cron": "^3.0.3",
    "openai": "^4.24.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
